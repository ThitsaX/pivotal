MYSQL_HOST_PORT=3306
NATS_HOST_PORT=4222
NATS_MONITOR_HOST_PORT=8222
REDIS_HOST_PORT=6379
WEB_OUTBOUND_HOST_PORT=3200
WEB_INBOUND_HOST_PORT=3201
WEB_PIVOTAL_HOST_PORT=3202
PORTAL_HOST_PORT=4173

WEB_OUTBOUND_PORT=3200
WEB_INBOUND_PORT=3201
WEB_PIVOTAL_PORT=3202

DB_WRITE_HOST=mysql
DB_WRITE_PORT=3306
DB_WRITE_USERNAME=root
DB_WRITE_PASSWORD=mysql
DB_WRITE_NAME=pivotal

DB_READ_HOST=mysql
DB_READ_PORT=3306
DB_READ_USERNAME=root
DB_READ_PASSWORD=mysql
DB_READ_NAME=pivotal

NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379
REDIS_CACHE_ITEM_TIMEOUT_MS=900000
PIVOTAL_AUDIT_STREAM_NAME=PIVOTAL_AUDIT
PIVOTAL_FSPIOP_STREAM_NAME=PIVOTAL_FSPIOP
PARTICIPANT_KEY_STORE_REFRESH_INTERVAL_SECONDS=5

FSPIOP_PARTIES_URL=http://web-inbound:3201
FSPIOP_QUOTES_URL=http://web-inbound:3201
FSPIOP_TRANSFERS_URL=http://web-inbound:3201
FSPIOP_SWITCH_ID=hub

FSPIOP_SIGN_JWS=false
FSPIOP_VERIFY_JWS=false
FSPIOP_USE_JWS=false
FSPIOP_MUTUAL_TLS=false
FSPIOP_USE_MUTUAL_TLS=false
FSPIOP_TLS_VERIFY_SERVER_CERT=false
FSPIOP_TLS_VERIFY_DOMAIN=false
FSPIOP_SOCKET_TIMEOUT_MS=30000
FSPIOP_CONNECTION_TIMEOUT_MS=5000

# JWT access policy (web-outbound)
ACCESS_JWT_ENABLED=true

WALLET1_CONNECTOR_ID=wallet1
WALLET1_CONNECTOR_SUPPORTED_CURRENCIES=USD,LRD
WALLET1_CONNECTOR_ILP_SECRET=wallet1-ilp-secret
WALLET2_CONNECTOR_ID=wallet2
WALLET2_CONNECTOR_SUPPORTED_CURRENCIES=USD,LRD
WALLET2_CONNECTOR_ILP_SECRET=wallet2-ilp-secret
WALLET3_CONNECTOR_ID=wallet3
WALLET3_CONNECTOR_SUPPORTED_CURRENCIES=USD,LRD
WALLET3_CONNECTOR_ILP_SECRET=wallet3-ilp-secret

CATALYST_URL=http://host.docker.internal:4000
CATALYST_ENGINE_MODE=STRICT
CENTRAL_LEDGER_URL=http://host.docker.internal:3001
CENTRAL_LEDGER_SOCKET_TIMEOUT_MS=
CENTRAL_LEDGER_CONNECTION_TIMEOUT_MS=
VITE_WEB_PIVOTAL_API_BASE_URL=http://localhost:3202

# Portal report download polling (ms). Used by the UI (portal container).
REPORT_DOWNLOAD_JOB_TTL_MIN=15
REPORT_DOWNLOAD_READY_TTL_HOURS=24
REPORT_DOWNLOAD_POLL_INTERVAL_SEC=30

# Report download worker settings. The worker must be enabled for report
# requests to move from PENDING to READY/FAILED.
REPORT_DOWNLOAD_WORKER_ENABLED=true
REPORT_DOWNLOAD_POLL_INTERVAL_MS=5000
REPORT_DOWNLOAD_PAGE_SIZE=50000
REPORT_DOWNLOAD_MAX_ROWS_PER_FILE=50000
REPORT_DOWNLOAD_MAX_ZIP_FILES=1
REPORT_DOWNLOAD_MAX_CONCURRENT=3
REPORT_DOWNLOAD_STALE_RUNNING_TTL_MS=1200000

# Report object storage settings used by web-pivotal. These defaults are
# AWS S3-shaped placeholders; set real values when REPORT_S3_ENABLED=true.
# For local MinIO testing, override these values to match the MinIO section
# below, for example:
# REPORT_S3_ENABLED=true
# REPORT_S3_BUCKET=pivotal-reports
# REPORT_S3_ACCESS_KEY_ID=minioadmin
# REPORT_S3_SECRET_ACCESS_KEY=minioadmin
# REPORT_S3_ENDPOINT=http://minio:9000
# REPORT_S3_FORCE_PATH_STYLE=true
REPORT_S3_ENABLED=false
REPORT_S3_BUCKET=your-aws-s3-bucket-name
REPORT_S3_REGION=us-east-1
REPORT_S3_ACCESS_KEY_ID=your-aws-access-key-id
REPORT_S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
REPORT_S3_ENDPOINT=
REPORT_S3_FORCE_PATH_STYLE=false
REPORT_S3_PREFIX=reports/
REPORT_S3_PRESIGNED_URL_TTL_SECONDS=900

# Local-only MinIO bootstrap values for the docker compose "reports" profile.
# These do not configure web-pivotal S3 uploads by themselves.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REPORT_BUCKET=pivotal-reports

FSPIOP_JWS_PRIVATE_KEY=
FSPIOP_JWS_PUBLIC_KEY=
FSPIOP_MTLS_CA=
FSPIOP_MTLS_CLIENT_CERT=
FSPIOP_MTLS_CLIENT_KEY=
