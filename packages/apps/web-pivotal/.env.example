WEB_PIVOTAL_PORT=3202

DB_WRITE_HOST=localhost
DB_WRITE_PORT=3306
DB_WRITE_USERNAME=central_ledger
DB_WRITE_PASSWORD=password
DB_WRITE_NAME=pivotal

DB_READ_HOST=localhost
DB_READ_PORT=3306
DB_READ_USERNAME=central_ledger
DB_READ_PASSWORD=password
DB_READ_NAME=pivotal

CENTRAL_LEDGER_URL=http://localhost:3001

# === Pivotal IAM (Phase 1) ===

# REQUIRED — backend refuses to start without these.
PIVOTAL_IAM_JWT_SECRET= --your-jwt-secret-here--
PIVOTAL_IAM_ADMIN_SEED_EMAIL=admin@pivotal.com
PIVOTAL_IAM_ADMIN_SEED_TEMP_PASSWORD=ChangeMe123!

# REQUIRED for the portal at :4173 (vite preview) and :5173 (vite dev) to reach the API at :3202.
PIVOTAL_IAM_CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173

# OPTIONAL — defaults shown; uncomment only to override.
# PIVOTAL_IAM_JWT_ISSUER=pivotal
# PIVOTAL_IAM_ACCESS_TOKEN_TTL_SECONDS=900
# PIVOTAL_IAM_REFRESH_TOKEN_TTL_DAYS=14
# PIVOTAL_IAM_BCRYPT_COST_FACTOR=12
# PIVOTAL_IAM_LOGIN_LOCKOUT_THRESHOLD=5
# PIVOTAL_IAM_LOGIN_LOCKOUT_MINUTES=15

# === Audit (Find Transactions) ===

# OPTIONAL — hard cap on rows the query scans/counts/returns. Defaults to 500000.
# Result sets larger than this display as "~500,000+". Increase only with index headroom.
AUDIT_MAX_RESULT_ROWS=500000
