# NATS
NATS_URL=nats://localhost:4222
PIVOTAL_AUDIT_STREAM_NAME=PIVOTAL_AUDIT

# JetStream retention limits (enforced by app-auditor's StreamLimitsEnforcer)
# Bounds JetStream storage so the PVC can't grow unbounded — transactions are the system of
# record in MySQL, so streams don't need to keep data forever. `max_age` is the real bound;
# `max_bytes` stays unlimited (-1) on purpose — a tight byte cap with discard=old would drop
# the OLDEST (possibly not-yet-consumed) messages first, i.e. silent data loss.
# All optional: the values below are also the built-in code defaults.
#
# PIVOTAL_FSPIOP (`fspiop.>`) is created/owned by the Java connectors; app-auditor only
# tightens its limits from the shared NATS account (it never creates this stream).
PIVOTAL_FSPIOP_STREAM_NAME=PIVOTAL_FSPIOP
PIVOTAL_FSPIOP_STREAM_MAX_AGE_MS=3600000        # 1h — transient connector request/response traffic
PIVOTAL_FSPIOP_STREAM_MAX_BYTES=-1              # unlimited (bound by age)
# PIVOTAL_AUDIT (`audit.>`) is pivotal-owned; 48h keeps a poison-message/DLQ replay buffer.
PIVOTAL_AUDIT_STREAM_MAX_AGE_MS=172800000       # 48h
PIVOTAL_AUDIT_STREAM_MAX_BYTES=-1              # unlimited (bound by age)
# How often the enforcer re-checks/applies the limits above. Idempotent and safe across the
# 2–5 app-auditor replicas (each tick reads config and only updates on drift). Operational
# cadence knob only — the policy itself is enforced continuously by the NATS server.
PIVOTAL_STREAM_LIMITS_ENFORCE_INTERVAL_MS=600000    # 10m

# Write DB settings
DB_WRITE_HOST=localhost
DB_WRITE_PORT=3306
DB_WRITE_USERNAME=central_ledger
DB_WRITE_PASSWORD=password
DB_WRITE_NAME=pivotal

# Read DB settings
DB_READ_HOST=localhost
DB_READ_PORT=3306
DB_READ_USERNAME=central_ledger
DB_READ_PASSWORD=password
DB_READ_NAME=pivotal

# Dashboard transaction rollup
# Periodically re-aggregates `transactions` into `transaction_hourly_rollup` (powers the
# portal dashboard). Runs in-process; a Redis lock ensures only one app-auditor replica
# refreshes per tick, so REDIS_URL is required.
#
# INTERVAL controls only freshness (how often the job runs) and is safe to tune. The
# re-aggregation WINDOW (how far back each run recomputes) is NOT configurable — it is fixed
# in code, because a too-small window would silently produce wrong (stale) statistics.
TRANSACTION_ROLLUP_INTERVAL_SECONDS=300
REDIS_URL=redis://localhost:7379
