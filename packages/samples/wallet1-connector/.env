# NATS
NATS_URL=nats://localhost:4222
PIVOTAL_FSPIOP_STREAM_NAME=PIVOTAL_FSPIOP

# FSPIOP callback settings
FSPIOP_PARTIES_URL=http://localhost:4002
FSPIOP_QUOTES_URL=http://localhost:3002
FSPIOP_TRANSFERS_URL=http://localhost:3000
FSPIOP_SWITCH_ID=hub
FSPIOP_USE_JWS=false
FSPIOP_USE_MUTUAL_TLS=false
FSPIOP_TLS_VERIFY_SERVER_CERT=false
FSPIOP_TLS_VERIFY_DOMAIN=false

# Optional timeout settings (milliseconds)
# FSPIOP_SOCKET_TIMEOUT_MS=
# FSPIOP_CONNECTION_TIMEOUT_MS=

# Connector settings
CONNECTOR_ID=wallet1
CONNECTOR_SUPPORTED_CURRENCIES=USD,LRD
CONNECTOR_ILP_SECRET=wallet1-ilp-secret

# Catalyst fee service settings
CATALYST_URL=http://localhost:8081
CATALYST_ENGINE_MODE=STRICT

# Optional: required only when FSPIOP_USE_JWS=false and/or FSPIOP_USE_MUTUAL_TLS=false
# FSPIOP_JWS_PUBLIC_KEY=
# FSPIOP_JWS_PRIVATE_KEY=
# FSPIOP_MTLS_CA=
# FSPIOP_MTLS_CLIENT_CERT=
# FSPIOP_MTLS_CLIENT_KEY=

