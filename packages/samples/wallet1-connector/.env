# NATS
NATS_URL=nats://localhost:4222
PAYPORT_FSPIOP_STREAM_NAME=PAYPORT_FSPIOP

# FSPIOP callback settings
FSPIOP_SWITCH_BASE_URL=http://localhost:4000
FSPIOP_SWITCH_ID=switch
FSPIOP_USE_JWS=false
FSPIOP_USE_MUTUAL_TLS=false

# Optional timeout settings (milliseconds)
# FSPIOP_SOCKET_TIMEOUT_MS=
# FSPIOP_CONNECTION_TIMEOUT_MS=

# Connector settings
CONNECTOR_ID=wallet1
CONNECTOR_SUPPORTED_CURRENCIES=USD
CONNECTOR_ILP_SECRET=wallet1-ilp-secret

# Optional: required only when FSPIOP_USE_JWS=true and/or FSPIOP_USE_MUTUAL_TLS=true
# FSP_IDS=wallet1,switch
# PRIVATE_KEY_WALLET1=
# PUBLIC_KEY_SWITCH=
# CA_COUNT=1
# CA_CONTENT_1=
# CLIENT_CERT_CONTENT=
# CLIENT_CERT_KEY=
