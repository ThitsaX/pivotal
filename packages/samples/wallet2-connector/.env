# NATS
NATS_URL=nats://localhost:4222
PAYPORT_FSPIOP_STREAM_NAME=PAYPORT_FSPIOP

# FSPIOP callback settings
FSPIOP_SWITCH_BASE_URL=https://localhost:3201
FSPIOP_SWITCH_ID=switch
FSPIOP_USE_JWS=true
FSPIOP_USE_MUTUAL_TLS=true
FSPIOP_TLS_VERIFY_SERVER_CERT=false
FSPIOP_TLS_VERIFY_DOMAIN=false

# Optional timeout settings (milliseconds)
# FSPIOP_SOCKET_TIMEOUT_MS=
# FSPIOP_CONNECTION_TIMEOUT_MS=

# Connector settings
CONNECTOR_ID=wallet2
CONNECTOR_SUPPORTED_CURRENCIES=USD
CONNECTOR_ILP_SECRET=wallet2-ilp-secret

# Optional: required only when FSPIOP_USE_JWS=true and/or FSPIOP_USE_MUTUAL_TLS=true
# FSPIOP_FSP_IDS=wallet2,switch
# FSPIOP_JWS_PRIVATE_KEY_WALLET2=
# FSPIOP_JWS_PUBLIC_KEY_SWITCH=
# FSPIOP_MTLS_CA_COUNT=1
# FSPIOP_MTLS_CA_CONTENT_1=
# CLIENT_CERT_CONTENT=
# CLIENT_CERT_KEY=
PUBLIC_KEY_STORE_FACTORY=env
PRIVATE_KEY_STORE_FACTORY=env
CA_CERT_STORE_FACTORY=env
CLIENT_CERT_STORE_FACTORY=env
