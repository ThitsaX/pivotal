# =============================================================================
# shared/security — required environment variables
# =============================================================================
# Copy the variables you need into your .env file and fill in the values.
# Variables marked [REQUIRED] must be set; [OPTIONAL] have a fallback.
# =============================================================================


# -----------------------------------------------------------------------------
# Keys — PublicKeyStoreFactory
# (component/key/public-key-store-factory.ts)
# Selects which loader populates PublicKeyStore at startup.
# Supported values: env (default), json
# -----------------------------------------------------------------------------

# [OPTIONAL] Defaults to 'env' when absent.
PUBLIC_KEY_STORE_FACTORY=env

# [OPTIONAL] Defaults to 'env' when absent.
PRIVATE_KEY_STORE_FACTORY=env


# -----------------------------------------------------------------------------
# Keys — EnvBasedPrivateKeyLoader / EnvBasedPublicKeyLoader
# (component/key/loader/env-based-private-key-loader.ts)
# (component/key/loader/env-based-public-key-loader.ts)
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma-separated list of FSP IDs whose keys should be loaded.
# If empty, no keys are loaded (no error).
FSP_IDS=FSP1,FSP2

# [REQUIRED per FSP ID listed in FSP_IDS]
# Private key (PEM) for each FSP. Embedded newlines may be escaped as \n.
PRIVATE_KEY_FSP1=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PRIVATE_KEY_FSP2=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# [REQUIRED per FSP ID listed in FSP_IDS]
# Public key (PEM) for each FSP. Embedded newlines may be escaped as \n.
PUBLIC_KEY_FSP1=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
PUBLIC_KEY_FSP2=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----


# -----------------------------------------------------------------------------
# Keys — JsonBasedPrivateKeyLoader / JsonBasedPublicKeyLoader
# (component/key/keystore.module.ts)
# Use these as an alternative to the per-FSP env vars above.
# Format: { "FSP_ID": "PEM_CONTENT", ... }
# -----------------------------------------------------------------------------

# [OPTIONAL] JSON object of FSP ID → private key PEM pairs.
JSON_PRIVATE_KEYS={"FSP1":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"}

# [OPTIONAL] JSON object of FSP ID → public key PEM pairs.
JSON_PUBLIC_KEYS={"FSP1":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}


# -----------------------------------------------------------------------------
# CA Certificates — CaStoreFactory
# (component/cert/ca-store-factory.ts)
# Selects which loader populates CaStore at startup.
# Supported values: env (default), json
# -----------------------------------------------------------------------------

# [OPTIONAL] Defaults to 'env' when absent.
CA_CERT_STORE_FACTORY=env


# -----------------------------------------------------------------------------
# CA Certificates — EnvBasedCaCertLoader
# (component/cert/loader/env-based-ca-cert-loader.ts)
# -----------------------------------------------------------------------------

# [OPTIONAL] Total number of CA certificates to load. If absent or 0, no
# certs are loaded. Each index from 1 to CA_COUNT must have a matching
# CA_CONTENT_N variable.
CA_COUNT=2

# [REQUIRED for each index 1..CA_COUNT]
# PEM content of each CA certificate. Embedded newlines may be escaped as \n.
CA_CONTENT_1=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
CA_CONTENT_2=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----


# -----------------------------------------------------------------------------
# CA Certificates — JsonBasedCaCertLoader
# (component/cert/cert.module.ts)
# Use this as an alternative to CA_COUNT / CA_CONTENT_N above.
# Format: ["CA1_PEM", "CA2_PEM", ...]
# -----------------------------------------------------------------------------

# [OPTIONAL] JSON array of CA certificate PEM strings.
JSON_CA_CERTS=["-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----","-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"]


# -----------------------------------------------------------------------------
# Client Certificate — ClientCertStoreFactory
# (component/client-cert/client-cert-store-factory.ts)
# Selects which loader populates ClientCertStore at startup.
# Supported values: env (default), json
# -----------------------------------------------------------------------------

# [OPTIONAL] Defaults to 'env' when absent.
CLIENT_CERT_STORE_FACTORY=env


# -----------------------------------------------------------------------------
# Client Certificate — EnvBasedClientCertLoader
# (component/client-cert/loader/env-based-client-cert-loader.ts)
# Both vars must be set together. If neither is set, no client cert is loaded.
# -----------------------------------------------------------------------------

# [OPTIONAL] PEM content of the client certificate. Embedded newlines may be escaped as \n.
CLIENT_CERT_CONTENT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# [OPTIONAL] PEM content of the client private key. Embedded newlines may be escaped as \n.
CLIENT_CERT_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----


# -----------------------------------------------------------------------------
# Client Certificate — JsonBasedClientCertLoader
# (component/client-cert/loader/json-based-client-cert-loader.ts)
# Use this as an alternative to the env vars above.
# Format: { "clientCert": "PEM", "clientKey": "PEM" }
# -----------------------------------------------------------------------------

# [OPTIONAL] JSON object with clientCert and clientKey PEM fields.
JSON_CLIENT_CERT={"clientCert":"-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----","clientKey":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"}
