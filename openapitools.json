{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.12.0",
    "generators": {
      "fspiop-dto": {
        "generatorName": "typescript-nestjs",
        "inputSpec": "packages/shared/fspiop/spec/fspiop_v2.yaml",
        "output": "packages/shared/fspiop/dto",
        "globalProperty": "models",
        "additionalProperties": {
          "modelSuffix": "",
          "fileNaming": "kebab-case",
          "modelPackage": ".",
          "stringEnums": true
        }
      },
      "fspiop-axios": {
        "generatorName": "typescript-axios",
        "inputSpec": "packages/shared/fspiop/spec/fspiop_v2.yaml",
        "output": "packages/shared/fspiop/component/axios",
        "globalProperty": "apis,supportingFiles",
        "additionalProperties": {
          "withSeparateModelsAndApi": true,
          "apiPackage": "api",
          "modelPackage": "model",
          "fileNaming": "kebab-case",
          "stringEnums": true,
          "useSingleRequestParameter": false
        }
      }
    }
  }
}
