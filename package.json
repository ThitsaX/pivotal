{
  "name": "mtpa",
  "version": "0.0.1",
  "description": "MTPA - NestJS Monorepo",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:api-inbound": "nest build api-inbound",
    "build:api-outbound": "nest build api-outbound",
    "build:core-inbound-domain": "nest build core-inbound-domain",
    "build:core-outbound-domain": "nest build core-outbound-domain",
    "build:core-outbound-subscriber": "nest build core-outbound-subscriber",
    "build:core-outbound-publisher": "nest build core-outbound-publisher",
    "build:core-audit-domain": "nest build core-audit-domain",
    "build:core-audit-subscriber": "nest build core-audit-subscriber",
    "build:core-audit-publisher": "nest build core-audit-publisher",
    "build:usecase-inbound": "nest build usecase-inbound",
    "build:usecase-outbound": "nest build usecase-outbound",
    "build:usecase-audit": "nest build usecase-audit",
    "build:shared-fspiop": "nest build shared-fspiop",
    "build:shared-snowflake": "nest build shared-snowflake",
    "build:shared-keystore": "nest build shared-keystore",
    "build:shared-interledger": "nest build shared-interledger",
    "build:shared-pgtype": "nest build shared-pgtype",
    "clean:fspiop-dto": "rm -rf packages/shared/fspiop/dto && mkdir -p packages/shared/fspiop/dto",
    "fix:fspiop-dto": "node scripts/fix-fspiop-dto.mjs",
    "generate:fspiop-dto:index": "node scripts/generate-fspiop-dto-index.mjs",
    "generate:fspiop-dto": "openapi-generator-cli generate --generator-key fspiop-dto && npm run fix:fspiop-dto && npm run generate:fspiop-dto:index",
    "regenerate:fspiop-dto": "npm run clean:fspiop-dto && npm run generate:fspiop-dto",
    "start:api-inbound": "nest start api-inbound",
    "start:api-outbound": "nest start api-outbound",
    "start:dev:api-inbound": "nest start api-inbound --watch",
    "start:dev:api-outbound": "nest start api-outbound --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/pg": "^8.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "ilp-packet": "^3.1.4-alpha.2",
    "nats": "^2.28.0",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
