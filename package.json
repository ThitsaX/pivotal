{
  "name": "pivotal",
  "version": "1.0.0",
  "description": "Pivotal : The multi-tenant payment adapter for Mojaloop",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:core-inbound-domain": "nest build core-inbound-domain",
    "build:core-connector-domain": "nest build core-connector-domain",
    "build:core-connector-consumer": "nest build core-connector-consumer",
    "build:core-connector-publisher": "nest build core-connector-publisher",
    "build:core-outbound-domain": "nest build core-outbound-domain",
    "build:core-audit-domain": "nest build core-audit-domain",
    "build:core-auth-domain": "nest build core-auth-domain",
    "build:core-audit-consumer": "nest build core-audit-consumer",
    "build:apps-app-auditor": "nest build apps-app-auditor",
    "build:apps-web-outbound": "nest build apps-web-outbound",
    "build:apps-web-inbound": "nest build apps-web-inbound",
    "build:apps-web-pivotal": "nest build apps-web-pivotal",
    "build:core-audit-subscriber": "nest build core-audit-subscriber",
    "build:core-audit-publisher": "nest build core-audit-publisher",
    "build:portal": "npm --prefix packages/portal run build",
    "start:apps-app-auditor": "nest start apps-app-auditor",
    "start:apps-app-auditor:dev": "nest start apps-app-auditor --watch",
    "start:apps-app-auditor:prod": "node dist/packages/apps/app-auditor/main.js",
    "start:apps-web-outbound": "nest start apps-web-outbound",
    "start:apps-web-outbound:dev": "nest start apps-web-outbound --watch",
    "start:apps-web-outbound:prod": "node dist/packages/apps/web-outbound/main.js",
    "start:apps-web-inbound": "nest start apps-web-inbound",
    "start:apps-web-inbound:dev": "nest start apps-web-inbound --watch",
    "start:apps-web-inbound:prod": "node dist/packages/apps/web-inbound/main.js",
    "start:apps-web-pivotal": "nest start apps-web-pivotal",
    "start:apps-web-pivotal:dev": "nest start apps-web-pivotal --watch",
    "start:apps-web-pivotal:prod": "node dist/packages/apps/web-pivotal/main.js",
    "dev:portal": "npm --prefix packages/portal run dev",
    "build:ports-fspiop": "nest build ports-fspiop",
    "build:ports-iso20022": "nest build ports-iso20022",
    "build:shared-axios": "nest build shared-axios",
    "build:shared-catalyst": "nest build shared-catalyst",
    "build:shared-central-ledger": "nest build shared-central-ledger",
    "build:shared-fspiop": "nest build shared-fspiop",
    "build:shared-dbmigration": "nest build shared-dbmigration",
    "build:shared-snowflake": "nest build shared-snowflake",
    "build:shared-interledger": "nest build shared-interledger",
    "build:shared-persistence": "nest build shared-persistence",
    "build:shared-foundation": "nest build shared-foundation",
    "build:shared-security": "nest build shared-security",
    "build:shared-ulid": "nest build shared-ulid",
    "build:samples-wallet1-connector": "nest build samples-wallet1-connector",
    "build:samples-wallet2-connector": "nest build samples-wallet2-connector",
    "build:samples-wallet3-connector": "nest build samples-wallet3-connector",
    "start:samples-wallet1-connector": "nest start samples-wallet1-connector",
    "start:samples-wallet1-connector:dev": "nest start samples-wallet1-connector --watch",
    "start:samples-wallet1-connector:prod": "node dist/packages/samples/wallet1-connector/main.js",
    "start:samples-wallet2-connector": "nest start samples-wallet2-connector",
    "start:samples-wallet2-connector:dev": "nest start samples-wallet2-connector --watch",
    "start:samples-wallet2-connector:prod": "node dist/packages/samples/wallet2-connector/main.js",
    "start:samples-wallet3-connector": "nest start samples-wallet3-connector",
    "start:samples-wallet3-connector:dev": "nest start samples-wallet3-connector --watch",
    "start:samples-wallet3-connector:prod": "node dist/packages/samples/wallet3-connector/main.js",
    "test:core-audit-domain:command": "node --test -r ts-node/register -r tsconfig-paths/register -r ./tests/core/audit/domain/command/env-setup.ts \"tests/core/audit/domain/command/**/*-test.ts\"",
    "test:core-outbound-domain:command": "node --test -r ts-node/register -r tsconfig-paths/register \"tests/core/outbound/domain/command/**/*-test.ts\"",
    "test:core-outbound-domain:component": "node --test -r ts-node/register -r tsconfig-paths/register \"tests/core/outbound/domain/component/**/*-test.ts\"",
    "test:core-audit-producer:publishers": "node --test -r ts-node/register -r tsconfig-paths/register -r ./tests/core/audit/producer/publishers/env-setup.ts \"tests/core/audit/producer/publishers/**/*-test.ts\"",
    "test:shared-security:jwt": "node --test -r ts-node/register tests/shared/security/component/jwt/jwt-test.ts",
    "test:shared-security": "node --test -r ts-node/register \"tests/shared/security/**/*-test.ts\"",
    "clean:fspiop-dto": "rm -rf packages/shared/fspiop/dto && mkdir -p packages/shared/fspiop/dto",
    "clean:catalyst-dto": "rm -rf packages/shared/catalyst/dto && mkdir -p packages/shared/catalyst/dto",
    "prepare:catalyst-dto-spec": "node scripts/prepare-catalyst-dto-spec.mjs",
    "fix:fspiop-dto": "node scripts/fix-fspiop-dto.mjs",
    "fix:catalyst-dto": "node scripts/fix-catalyst-dto.mjs",
    "generate:fspiop-dto:index": "node scripts/generate-fspiop-dto-index.mjs",
    "generate:catalyst-dto:index": "node scripts/generate-catalyst-dto-index.mjs",
    "generate:fspiop-dto": "openapi-generator-cli generate --generator-key fspiop-dto && npm run fix:fspiop-dto && npm run generate:fspiop-dto:index",
    "generate:catalyst-dto": "npm run prepare:catalyst-dto-spec && openapi-generator-cli generate --generator-key catalyst-dto && npm run fix:catalyst-dto && npm run generate:catalyst-dto:index",
    "regenerate:fspiop-dto": "npm run clean:fspiop-dto && npm run generate:fspiop-dto",
    "regenerate:catalyst-dto": "npm run clean:catalyst-dto && npm run generate:catalyst-dto"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "class-validator": "^0.14.4",
    "ilp-packet": "^3.1.4-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.2",
    "nats": "^2.28.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
