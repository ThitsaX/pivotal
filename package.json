{
  "name": "mtpa",
  "version": "0.0.1",
  "description": "MTPA - NestJS Monorepo",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:api-inbound": "nest build api-inbound",
    "build:api-outbound": "nest build api-outbound",
    "build:app-audit-subscriber": "nest build app-audit-subscriber",
    "build:app-fsp-subscriber": "nest build app-fsp-subscriber",
    "build:core-inbound": "nest build core-inbound",
    "build:core-outbound": "nest build core-outbound",
    "build:core-audit": "nest build core-audit",
    "build:usecase-inbound": "nest build usecase-inbound",
    "build:usecase-outbound": "nest build usecase-outbound",
    "build:usecase-audit": "nest build usecase-audit",
    "build:shared": "nest build shared",
    "start:api-inbound": "nest start api-inbound",
    "start:api-outbound": "nest start api-outbound",
    "start:app-audit-subscriber": "nest start app-audit-subscriber",
    "start:app-fsp-subscriber": "nest start app-fsp-subscriber",
    "start:dev:api-inbound": "nest start api-inbound --watch",
    "start:dev:api-outbound": "nest start api-outbound --watch",
    "start:dev:app-audit-subscriber": "nest start app-audit-subscriber --watch",
    "start:dev:app-fsp-subscriber": "nest start app-fsp-subscriber --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "nats": "^2.28.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
